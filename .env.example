# App data directory (relative paths below are resolved under this dir)
APP_DATA_DIR=backend/runtime

# SQLite cache + source data paths
SQLITE_CACHE_PATH=cache.db
DATA_DB_PATH=data.db
SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_CACHE_RETRY_ATTEMPTS=4
SQLITE_CACHE_RETRY_DELAY_MS=50
SQLITE_CACHE_SNAPSHOT_RETENTION=3
NEON_REBUILD_WORKSPACE_RETENTION=2

# Analytics
LOOKBACK_DAYS=504
RISK_RECOMPUTE_INTERVAL_DAYS=7
CROSS_SECTION_MIN_AGE_DAYS=7

# API CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Frontend API proxy target (used by frontend/next.config.js)
BACKEND_API_ORIGIN=http://127.0.0.1:8000
# Optional split control-plane target for Next proxy routes.
# Leave unset locally to reuse BACKEND_API_ORIGIN.
# In cloud steady state set this to the separate control origin.
BACKEND_CONTROL_ORIGIN=

# Production API worker count (keep 1 for current architecture)
BACKEND_WORKERS=1

# Runtime role
# local-ingest runs ingest + deeper refresh lanes; cloud-serve is serving-only.
APP_RUNTIME_ROLE=local-ingest
APP_ACCOUNT_ENFORCEMENT_ENABLED=false
APP_SHARED_AUTH_ACCEPT_LEGACY=false
ORCHESTRATOR_ENABLE_INGEST=false
SOURCE_DAILY_PIT_FREQUENCY=monthly

# Optional: when set, /api/refresh and /api/refresh/status require
# either X-Refresh-Token: <token> or Authorization: Bearer <token>.
REFRESH_API_TOKEN=
# Preferred steady-state operator/editor tokens.
# The frontend server-side proxy helpers prefer OPERATOR_API_TOKEN / EDITOR_API_TOKEN
# and only fall back to REFRESH_API_TOKEN for local compatibility.
OPERATOR_API_TOKEN=
EDITOR_API_TOKEN=

# Neon steady state
# Intended operating model: keep the full ingest/archive locally in SQLite, publish a rolling
# source/model window to Neon, and use Neon as the primary runtime model-data backend.
# Leave DATA_BACKEND=sqlite only for emergency fallback or a temporary first-time bootstrap without Neon.
DATA_BACKEND=neon
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
NEON_AUTO_SYNC_ENABLED=true
NEON_AUTO_SYNC_REQUIRED=true
NEON_AUTO_SYNC_MODE=incremental
# Comma-separated canonical tables; empty means all canonical tables.
NEON_AUTO_SYNC_TABLES=
NEON_AUTO_PARITY_ENABLED=true
NEON_AUTO_PRUNE_ENABLED=true
# Neon-only retention windows (SQLite remains full history by default).
NEON_SOURCE_RETENTION_YEARS=10
NEON_ANALYTICS_RETENTION_YEARS=5
# Transitional rebuild contract:
# false = local SQLite remains the core rebuild authority
# true = core/cold-core profiles are being migrated toward Neon-authoritative rebuild semantics
# operator status will expose both authoritative source dates and local archive dates so drift is visible
NEON_AUTHORITATIVE_REBUILDS=false
# When DATA_BACKEND=neon, durable serving payload reads become primary automatically.
# This flag is only for forcing Neon-backed serving reads before full backend cutover.
SERVING_OUTPUTS_PRIMARY_READS=false
# Controlled read cutover: comma-separated surfaces, or * for all.
# Supported: core_reads,factor_history,price_history,serving_outputs
NEON_READ_SURFACES=core_reads,factor_history,price_history

# Cloud deployment reference values (do not replace the local defaults above with these):
# Frontend public host: https://app.ceiora.com
# APP_RUNTIME_ROLE=cloud-serve
# DATA_BACKEND=neon
# CLOUD_RUN_JOBS_ENABLED=true
# CLOUD_RUN_PROJECT_ID=project-4e18de12-63a3-4206-aaa
# CLOUD_RUN_REGION=us-east4
# SERVE_REFRESH_CLOUD_RUN_JOB_NAME=ceiora-prod-serve-refresh
# BACKEND_API_ORIGIN=https://api.ceiora.com
# BACKEND_CONTROL_ORIGIN=https://control.ceiora.com
# OPERATOR_API_TOKEN=<operator-token>
# EDITOR_API_TOKEN=<editor-token>
# NEON_AUTHORITATIVE_REBUILDS=true
# APP_AUTH_PROVIDER=neon
# APP_AUTH_BOOTSTRAP_ENABLED=true
# APP_ACCOUNT_ENFORCEMENT_ENABLED=true
# APP_SHARED_AUTH_ACCEPT_LEGACY=false
# APP_ADMIN_SETTINGS_ENABLED=true
# NEON_AUTH_ISSUER=https://your-project.neon.tech/auth
# NEON_AUTH_JWKS_URL=https://your-project.neon.tech/auth/.well-known/jwks.json
# NEON_AUTH_AUDIENCE=
# NEON_AUTH_ALLOWED_EMAILS=<comma-separated allowlist>
# NEON_AUTH_BOOTSTRAP_ADMINS=<comma-separated bootstrap admins>

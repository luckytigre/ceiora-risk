# AWS Postgres (via SSH tunnel)
PG_HOST=localhost
PG_PORT=15432
PG_DB=portfolio_cold_dev
PG_USER=postgres
PG_PASSWORD=

# Data gatherer selection for backend/scripts/download_data.py
# lseg (default): uses jl-lseg-toolkit + LSEG Workspace
# postgres: uses legacy AWS Postgres snapshot pull
DATA_GATHERER=lseg

# SQLite cache path
SQLITE_CACHE_PATH=cache.db

# Analytics
LOOKBACK_DAYS=504
RISK_RECOMPUTE_INTERVAL_DAYS=7
CROSS_SECTION_MIN_AGE_DAYS=7

# Backend API target for Next.js rewrite proxy.
# This value is read at build time for the frontend image and should point at the
# serve API host for the target environment.
BACKEND_API_ORIGIN=http://localhost:8000

# Optional separate control-plane target for Next App Router proxy routes.
# Leave unset locally to fall back to BACKEND_API_ORIGIN.
BACKEND_CONTROL_ORIGIN=

# Frontend server-side proxy credentials.
# In cloud steady state these should come from runtime secrets, not local files.
OPERATOR_API_TOKEN=
EDITOR_API_TOKEN=

# Legacy compatibility token used only if the more specific tokens above are unset.
REFRESH_API_TOKEN=

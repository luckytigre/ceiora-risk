FROM node:20-alpine AS deps

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

COPY frontend/package.json frontend/package-lock.json ./

RUN npm ci --legacy-peer-deps

FROM node:20-alpine AS builder

WORKDIR /app

ARG BACKEND_API_ORIGIN=http://127.0.0.1:8000
ARG APP_AUTH_PROVIDER=shared
ARG APP_ACCOUNT_ENFORCEMENT_ENABLED=false
ARG APP_SHARED_AUTH_ACCEPT_LEGACY=false
ARG CEIORA_SESSION_SECRET=build-time-session-placeholder
ARG NEON_AUTH_BASE_URL=
ARG NEON_AUTH_ISSUER=
ARG NEON_AUTH_AUDIENCE=
ARG NEON_AUTH_JWKS_JSON=
ARG NEON_AUTH_ALLOWED_EMAILS=
ARG NEON_AUTH_BOOTSTRAP_ADMINS=
ENV BACKEND_API_ORIGIN=${BACKEND_API_ORIGIN}
ENV APP_AUTH_PROVIDER=${APP_AUTH_PROVIDER}
ENV APP_ACCOUNT_ENFORCEMENT_ENABLED=${APP_ACCOUNT_ENFORCEMENT_ENABLED}
ENV APP_SHARED_AUTH_ACCEPT_LEGACY=${APP_SHARED_AUTH_ACCEPT_LEGACY}
ENV CEIORA_SESSION_SECRET=${CEIORA_SESSION_SECRET}
ENV NEON_AUTH_BASE_URL=${NEON_AUTH_BASE_URL}
ENV NEON_AUTH_ISSUER=${NEON_AUTH_ISSUER}
ENV NEON_AUTH_AUDIENCE=${NEON_AUTH_AUDIENCE}
ENV NEON_AUTH_JWKS_JSON=${NEON_AUTH_JWKS_JSON}
ENV NEON_AUTH_ALLOWED_EMAILS=${NEON_AUTH_ALLOWED_EMAILS}
ENV NEON_AUTH_BOOTSTRAP_ADMINS=${NEON_AUTH_BOOTSTRAP_ADMINS}
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY frontend ./

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=builder /app ./

EXPOSE 3000

CMD ["sh", "-c", "npm run start -- -H 0.0.0.0 -p ${PORT:-3000}"]

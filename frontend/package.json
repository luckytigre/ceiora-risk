{
  "name": "cuse-dashboard-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node scripts/assert_node_version.mjs && next dev -H 127.0.0.1 -p 3000",
    "build": "node scripts/assert_node_version.mjs && NEXT_TELEMETRY_DISABLED=1 next build",
    "clean:artifacts": "rm -rf .next",
    "build:compile": "node scripts/assert_node_version.mjs && npm run clean:artifacts && NEXT_TELEMETRY_DISABLED=1 next build --experimental-build-mode compile && node scripts/assert_build_id.mjs",
    "build:generate": "node scripts/assert_node_version.mjs && node scripts/run_generate_build.mjs",
    "build:debug": "node scripts/assert_node_version.mjs && npm run clean:artifacts && NEXT_TELEMETRY_DISABLED=1 next build --debug --experimental-app-only",
    "start": "node scripts/assert_node_version.mjs && next start",
    "typegen": "node scripts/assert_node_version.mjs && node -e \"require('fs').mkdirSync('.next/types',{recursive:true})\" && next typegen",
    "typecheck": "npm run typegen && tsc --noEmit --incremental false",
    "test:control-plane-proxies": "node scripts/control_plane_proxy_contract_check.mjs",
    "test:smoke-seq": "npm run test:family-routes && npm run test:cpar-pages && npm run test:cpar-hedge && npm run test:cpar-portfolio && npm run test:cpar-portfolio-whatif && npm run test:explore-whatif && npm run test:explore-whatif-busy",
    "test:family-routes": "node scripts/family_routes_smoke.mjs",
    "test:cpar-pages": "node scripts/cpar_pages_smoke.mjs",
    "test:cpar-hedge": "node scripts/cpar_hedge_page_smoke.mjs",
    "test:cpar-portfolio": "node scripts/cpar_portfolio_smoke.mjs",
    "test:cpar-portfolio-whatif": "node scripts/cpar_portfolio_whatif_smoke.mjs",
    "test:explore-whatif": "node scripts/explore_whatif_refresh_regression.mjs",
    "test:explore-whatif-busy": "node scripts/explore_whatif_refresh_busy_regression.mjs"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.2.0-beta.1",
    "chart.js": "^4.4.0",
    "jose": "^5.10.0",
    "next": "^15.5.12",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.0",
    "swr": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "playwright": "^1.51.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}

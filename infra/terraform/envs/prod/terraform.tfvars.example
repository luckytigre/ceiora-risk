project_id                    = "project-4e18de12-63a3-4206-aaa"
environment                   = "prod"
region                        = "us-east4"
artifact_registry_repository_id = "ceiora-images"
cloudflare_zone_name          = "ceiora.com"
cloudflare_proxied            = false
endpoint_mode                 = "custom_domains"
edge_enabled                  = true

# Production should pin explicit image refs instead of relying on the default
# `image_tag = "latest"`. For config-only Terraform changes such as billing-mode
# updates, pin the currently deployed image refs so the plan only changes the
# intended service configuration.
# frontend_image_ref         = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/frontend:<tag>"
# serve_image_ref            = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/serve:<tag>"
# control_image_ref          = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/control:<tag>"

# run_app mode is explicit and fail-closed. Provide the full public-origin and
# pinned-image contract together when endpoint_mode = "run_app".
# Soak mode keeps the custom-domain edge up for rollback:
# endpoint_mode                   = "run_app"
# edge_enabled                    = true
# frontend_public_origin          = "https://<frontend-service>.run.app"
# frontend_backend_api_origin     = "https://<serve-service>.run.app"
# frontend_backend_control_origin = "https://<control-service>.run.app"
# frontend_image_ref              = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/frontend:<tag>"
# serve_image_ref                 = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/serve:<tag>"
# control_image_ref               = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/control:<tag>"

# Auth/runtime contract for the current Neon-authenticated app shape:
# app_auth_provider               = "neon"
# app_account_enforcement_enabled = true
# app_auth_bootstrap_enabled      = true
# app_admin_settings_enabled      = true
# app_shared_auth_accept_legacy   = false
# neon_auth_base_url              = "https://<tenant>/auth"
# neon_auth_issuer                = "https://<tenant>/auth"
# neon_auth_audience              = "https://<tenant>"
# neon_auth_jwks_json             = "{\"keys\":[...]}"
# neon_auth_allowed_emails        = ["user@example.com"]
# neon_auth_bootstrap_admins      = ["user@example.com"]

# Final no-edge run_app steady state flips only edge_enabled after soak:
# endpoint_mode                   = "run_app"
# edge_enabled                    = false
# frontend_public_origin          = "https://<frontend-service>.run.app"
# frontend_backend_api_origin     = "https://<serve-service>.run.app"
# frontend_backend_control_origin = "https://<control-service>.run.app"
# frontend_image_ref              = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/frontend:<tag>"
# serve_image_ref                 = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/serve:<tag>"
# control_image_ref               = "us-east4-docker.pkg.dev/project-4e18de12-63a3-4206-aaa/ceiora-images/control:<tag>"
